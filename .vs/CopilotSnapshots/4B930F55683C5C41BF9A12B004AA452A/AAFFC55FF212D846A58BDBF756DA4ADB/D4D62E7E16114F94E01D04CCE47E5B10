Bitmap bmp)
        {
            bmp.SetPixel(xc + x, yc + y, color);
            bmp.SetPixel(xc - x, yc + y, color);
            bmp.SetPixel(xc + x, yc - y, color);
            bmp.SetPixel(xc - x, yc - y, color);
            bmp.SetPixel(xc + y, yc + x, color);
            bmp.SetPixel(xc - y, yc + x, color);
            bmp.SetPixel(xc + y, yc - x, color);
            bmp.SetPixel(xc - y, yc - x, color);
            pictureBox1.Image = bmp;
        }
        private void RunMidpointCircle(int xc, int yc, int r, Color color, Bitmap bmp)
        {
            int x = 0;
            int y = r;
            int p = 1 - r;

            while (x <= y)
            {
                Draw8Points(xc, yc, x, y, color, bmp);

                System.Threading.Thread.Sleep(15);
                pictureBox1.Refresh();
                pictureBox1.Image = bmp;
                x++;

                if (p < 0)
                {
                    p = p + (x << 1) + 1;
                }
                else
                {
                    y--;
                    p = p + (x << 1) - (y << 1) + 1;
                }
            }
            pictureBox1.Image = bmp;
        }
