        // المختبر الثالث
        private void RunDDA(int x1, int y1, int x2, int y2, Color color)
        {
            float dx = x2 - x1;
            float dy = y2 - y1;
            float steps = Math.Max(Math.Abs(dx), Math.Abs(dy));
            float xInc = dx / steps;
            float yInc = dy / steps;
            float x = x1, y = y1;

            for (int i = 0; i <= steps; i++)
            {
                int ix = (int)Math.Round(x);
                int iy = (int)Math.Round(y);

                if (ix >= 0 && ix < bmp.Width && iy >= 0 && iy < bmp.Height)
                {
                    bmp.SetPixel(ix, iy, color);
                    pixelCount++;
                    ApplyDelay();
                }

                x += xInc;
                y += yInc;
            }
        }

