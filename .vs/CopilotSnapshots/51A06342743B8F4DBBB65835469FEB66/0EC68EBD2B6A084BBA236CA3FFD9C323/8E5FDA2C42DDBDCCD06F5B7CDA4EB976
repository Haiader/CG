        // المختبر الرابع
        private void Draw8Points(int xc, int yc, int x, int y, Color color)
        {
            void SafeSet(int sx, int sy)
            {
                if (sx >= 0 && sx < bmp.Width && sy >= 0 && sy < bmp.Height)
                {
                    bmp.SetPixel(sx, sy, color);
                    pixelCount++;
                }
            }

            SafeSet(xc + x, yc + y);
            SafeSet(xc - x, yc + y);
            SafeSet(xc + x, yc - y);
            SafeSet(xc - x, yc - y);
            SafeSet(xc + y, yc + x);
            SafeSet(xc - y, yc + x);
            SafeSet(xc + y, yc - x);
            SafeSet(xc - y, yc - x);
        }

        private void RunMidpointCircle(int xc, int yc, int r, Color color)
        {
            int x = 0, y = r;
            int p = 1 - r;

            while (x <= y)
            {
                Draw8Points(xc, yc, x, y, color);
                x++;

                if (p < 0)
                    p = p + (x << 1) + 1;
                else
                {
                    y--;
                    p = p + (x << 1) - (y << 1) + 1;
                }
            }
        }

