            float TimeinSecond = drawTimer.ElapsedMilliseconds/1000;
            lblMetrics.Text = $"{algorithmName}\nTime: {drawTimer.ElapsedMilliseconds}ms [~{TimeinSecond}s] | Pixels: {pixelCount}";

