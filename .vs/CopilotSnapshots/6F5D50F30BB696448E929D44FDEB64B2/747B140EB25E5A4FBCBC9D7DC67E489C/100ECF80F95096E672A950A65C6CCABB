        private void DrawLine(Bitmap bmp, int x1, int y1, int x2, int y2)
        {
            int dx = Math.Abs(x2 - x1);
            int dy = Math.Abs(y2 - y1);
            int sx = x1 < x2 ? 1 : -1;
            int sy = y1 < y2 ? 1 : -1;
            int err = dx - dy;

            bool slow = IsSlow("DrawLineGeneric");

            while (true)
            {
                if (x1 >= 0 && x1 < bmp.Width && y1 >= 0 && y1 < bmp.Height)
                    bmp.SetPixel(x1, y1, Color.Black);

                if (x1 == x2 && y1 == y2) break;
                int e2 = err * 2;
                if (e2 > -dy) { err -= dy; x1 += sx; }
                if (e2 < dx) { err += dx; y1 += sy; }

                if (slow)
                {
                    pictureBox1.Image = bmp;
                    pictureBox1.Refresh();
                    Thread.Sleep(6);
                }
            }
        }

