        private void RunPolarCircle(int xc, int yc, int r, Color color, Bitmap bmp)
        {
            bool slow = IsSlow("PolarCircle");

            for (double theta = 0; theta <= 360; theta += 1)
            {
                double radian = theta * (Math.PI / 180.0);

                int x = (int)Math.Round(r * Math.Cos(radian));
                int y = (int)Math.Round(r * Math.Sin(radian));

                if (xc + x >= 0 && xc + x < bmp.Width && yc + y >= 0 && yc + y < bmp.Height)
                    bmp.SetPixel(xc + x, yc + y, color);

                if (slow)
                {
                    Thread.Sleep(10);
                    pictureBox1.Refresh();
                    pictureBox1.Image = bmp;
                }
            }

            pictureBox1.Image = bmp;
        }
