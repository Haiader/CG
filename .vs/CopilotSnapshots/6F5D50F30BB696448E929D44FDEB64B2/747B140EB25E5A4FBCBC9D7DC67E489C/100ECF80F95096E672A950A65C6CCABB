        void RunDDA(int x1, int y1, int x2, int y2, Color color, Bitmap bmp, PictureBox pbox)
        {
            float dx = x2 - x1;
            float dy = y2 - y1;
            float steps = Math.Max(Math.Abs(dx), Math.Abs(dy));
            float xInc = dx / steps;
            float yInc = dy / steps;
            float x = x1;
            float y = y1;

            bool slow = IsSlow("DDA");

            for (int i = 0; i <= steps; i++)
            {
                int ix = (int)Math.Round(x);
                int iy = (int)Math.Round(y);

                if (ix >= 0 && ix < bmp.Width && iy >= 0 && iy < bmp.Height)
                {
                    bmp.SetPixel(ix, iy, color);
                }

                x += xInc;
                y += yInc;

                if (slow)
                {
                    Thread.Sleep(10);
                    pbox.Image = bmp;
                    pbox.Refresh();
                }
            }

            if (!slow)
            {
                pbox.Image = bmp;
            }
        }
