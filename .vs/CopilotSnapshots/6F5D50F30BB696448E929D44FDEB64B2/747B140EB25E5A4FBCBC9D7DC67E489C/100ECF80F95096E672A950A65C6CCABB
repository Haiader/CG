        void RunBresenham(int x1, int y1, int x2, int y2, Color color, Bitmap bmp)
        {
            // This Bresenham implementation assumes x1 <= x2 for the simple loop as in original
            int dx = Math.Abs(x2 - x1);
            int dy = Math.Abs(y2 - y1);

            int p = 2 * dy - dx;
            int y = y1;

            bool slow = IsSlow("Bresenham");

            int sx = x1 < x2 ? 1 : -1;
            int sy = y1 < y2 ? 1 : -1;
            int err = dx - dy;
            int x = x1;

            while (true)
            {
                if (x >= 0 && x < bmp.Width && y >= 0 && y < bmp.Height)
                    bmp.SetPixel(x, y, color);

                if (x == x2 && y == y2) break;

                int e2 = err * 2;
                if (e2 > -dy) { err -= dy; x += sx; }
                if (e2 < dx) { err += dx; y += sy; }

                if (slow)
                {
                    pictureBox1.Image = bmp;
                    pictureBox1.Refresh();
                    Thread.Sleep(8);
                }
            }

            pictureBox1.Image = bmp;
        }

