        private void pictureBox1_MouseDown(object sender, MouseEventArgs e)
        {
            isDrawing = true;
            freehandPoints.Clear();
            freehandPoints.Add(e.Location);

            backupBmp = (Bitmap)bmp.Clone();
        }

        private void pictureBox1_MouseMove(object sender, MouseEventArgs e)
        {
            label6 .Text = $"X: {e.X}, Y: {e.Y}"; 
            if (isDrawing)
            {
                freehandPoints.Add(e.Location); 

                int lastIndex = freehandPoints.Count - 1;
                using (Graphics g = Graphics.FromImage(bmp))
                {
                    Pen pen = new Pen(Color.Gray, 2);
                    g.DrawLine(pen, freehandPoints[lastIndex - 1], freehandPoints[lastIndex]);
                }
                pictureBox1.Image = bmp;
            }
        }

        private void pictureBox1_MouseUp(object sender, MouseEventArgs e)
        {
            if (!isDrawing) return;
            isDrawing = false;

            bmp = (Bitmap)backupBmp.Clone(); 

            if (freehandPoints.Count > 10)
            {
                Point startPt = freehandPoints.First();
                Point endPt = freehandPoints.Last();
                double distance = Math.Sqrt(Math.Pow(endPt.X - startPt.X, 2) + Math.Pow(endPt.Y - startPt.Y, 2));

                if (distance > 50)
                {
                    DrawLine(bmp, startPt.X, startPt.Y, endPt.X, endPt.Y);
                }
                else
                {
                    int minX = freehandPoints.Min(p => p.X);
                    int maxX = freehandPoints.Max(p => p.X);
                    int minY = freehandPoints.Min(p => p.Y);
                    int maxY = freehandPoints.Max(p => p.Y);

                    int W = maxX - minX; 
                    int H = maxY - minY; 

                    int t = 30;

                    bool hitTopLeft = freehandPoints.Any(p => Math.Abs(p.X - minX) < t && Math.Abs(p.Y - minY) < t);
                    bool hitTopRight = freehandPoints.Any(p => Math.Abs(p.X - maxX) < t && Math.Abs(p.Y - minY) < t);
                    bool hitTopMid = freehandPoints.Any(p => Math.Abs(p.X - (minX + W / 2)) < t && Math.Abs(p.Y - minY) < t);


                    if (hitTopLeft && hitTopRight)
                    {
                        if (Math.Abs(W - H) < 40)
                        {
                            int size = Math.Max(W, H);
                            DrawShape(minX, minY, minX + size, minY, minX + size, minY + size, minX, minY + size, Color.Green, bmp, pictureBox1);
                        }
                        else 
                        {
                            DrawShape(minX, minY, maxX, minY, maxX, maxY, minX, maxY, Color.Green, bmp, pictureBox1);
                        }
                    }
                    else if (hitTopMid && !hitTopLeft && !hitTopRight)
                    {
                        DrawShape(minX + W / 2, minY, maxX, maxY, minX, maxY, Color.Orange, bmp, pictureBox1);
                    }
                    else
                    {
                        int r = Math.Max(W, H) / 2;
                        RunMidpointCircle(minX + r, minY + r, r, Color.Blue, bmp);
                    }
                }
            }
            pictureBox1.Image = bmp;
        }

