## ? Integration Patterns

### Pattern 1: Simple Algorithm
```csharp
private void button_Click(object sender, EventArgs e)
{
    BeginPerformanceMeasurement("AlgorithmName");
    ClearCanvas();
    SimpleAlgorithm();
    pictureBox1.Image = bmp;
    EndPerformanceMeasurement();
}
```

### Pattern 2: Multiple Calls
```csharp
private void button_Click(object sender, EventArgs e)
{
    BeginPerformanceMeasurement("CompositeAlgorithm");
    ClearCanvas();
    Function1();
    Function2();
    Function3();  // All measured together
    pictureBox1.Image = bmp;
    EndPerformanceMeasurement();
}
```

### Pattern 3: Nested Loops
```csharp
private void button_Click(object sender, EventArgs e)
{
    BeginPerformanceMeasurement("ComplexAlgorithm");
    ClearCanvas();
    bool slow = IsSlow("ComplexAlgorithm");
    
    for (int i = 0; i < 1000; i++)
    {
        // Work
        if (slow && i % 10 == 0)
        {
            pictureBox1.Image = bmp;
            pictureBox1.Refresh();
            Thread.Sleep(5);
        }
    }
    pictureBox1.Image = bmp;
    EndPerformanceMeasurement();
}
```

