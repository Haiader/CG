### Pattern 4: Nested Loops with Refreshes
```csharp
private void button_Click(object sender, EventArgs e)
{
    BeginPerformanceMeasurement("ComplexAlgorithm");
    ClearCanvas();
    bool slow = IsSlow("ComplexAlgorithm");
    
    for (int i = 0; i < 1000; i++)
    {
        // Algorithm work
        if (slow && i % 10 == 0)
        {
            pictureBox1.Image = bmp;
            pictureBox1.Refresh();
            Thread.Sleep(5);
        }
    }
    pictureBox1.Image = bmp;
    EndPerformanceMeasurement();
}
```

