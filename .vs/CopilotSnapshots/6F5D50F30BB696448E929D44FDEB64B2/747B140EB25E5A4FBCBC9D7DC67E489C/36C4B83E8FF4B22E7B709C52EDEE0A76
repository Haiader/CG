        private void Draw8Points(int xc, int yc, int x, int y, Color color,
    Bitmap bmp)
        {
            // Safety checks added
            void SafeSet(int sx, int sy)
            {
                if (sx >= 0 && sx < bmp.Width && sy >= 0 && sy < bmp.Height)
                    bmp.SetPixel(sx, sy, color);
            }

            SafeSet(xc + x, yc + y);
            SafeSet(xc - x, yc + y);
            SafeSet(xc + x, yc - y);
            SafeSet(xc - x, yc - y);
            SafeSet(xc + y, yc + x);
            SafeSet(xc - y, yc + x);
            SafeSet(xc + y, yc - x);
            SafeSet(xc - y, yc - x);
            pictureBox1.Image = bmp;
        }
        private void RunMidpointCircle(int xc, int yc, int r, Color color, Bitmap bmp)
        {
            int x = 0;
            int y = r;
            int p = 1 - r;

            bool slow = IsSlow("MidpointCircle");

            while (x <= y)
            {
                Draw8Points(xc, yc, x, y, color, bmp);

                if (slow)
                {
                    Thread.Sleep(15);
                    pictureBox1.Refresh();
                    pictureBox1.Image = bmp;
                }
                x++;

                if (p < 0)
                {
                    p = p + (x << 1) + 1;
                }
                else
                {
                    y--;
                    p = p + (x << 1) - (y << 1) + 1;
                }
            }
            pictureBox1.Image = bmp;
        }
