        private void RunStandardCircle(int xc, int yc, int r, Color color, Bitmap bmp)
        {
            bool slow = IsSlow("StandardCircle");

            for (int x = 0; x <= r; x++)
            {
                double yCalc = Math.Sqrt((r * r) - (x * x));
                int y = (int)Math.Round(yCalc);

                if (xc + x >= 0 && xc + x < bmp.Width && yc + y >= 0 && yc + y < bmp.Height)
                    bmp.SetPixel(xc + x, yc + y, color);
                if (xc + x >= 0 && xc + x < bmp.Width && yc - y >= 0 && yc - y < bmp.Height)
                    bmp.SetPixel(xc + x, yc - y, color);
                if (xc - x >= 0 && xc - x < bmp.Width && yc + y >= 0 && yc + y < bmp.Height)
                    bmp.SetPixel(xc - x, yc + y, color);
                if (xc - x >= 0 && xc - x < bmp.Width && yc - y >= 0 && yc - y < bmp.Height)
                    bmp.SetPixel(xc - x, yc - y, color);

                if (slow)
                {
                    Thread.Sleep(10);
                    pictureBox1.Refresh();
                    pictureBox1.Image = bmp;
                }
            }
            pictureBox1.Image = bmp;
        }
