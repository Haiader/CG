        private void InitializeCpuMonitor()
        {
            try
            {
                cpuCounter = new PerformanceCounter("Processor", "% Processor Time", "_Total", true);
                _ = cpuCounter.NextValue();
            }
            catch
            {
                cpuCounter = null;
            }

            // إنشاء Label لعرض استهلاك المعالج في panel3
            lblCpuDisplay = new Label
            {
                Text = "CPU: 0%",
                Font = new Font("Arial", 14, FontStyle.Bold),
                ForeColor = Color.Black,
                BackColor = Color.LightGray,
                TextAlign = ContentAlignment.MiddleCenter,
                Dock = DockStyle.Fill
            };

            if (panel3 != null)
            {
                panel3.Controls.Clear();
                panel3.Controls.Add(lblCpuDisplay);
            }

            // تحديث استهلاك المعالج كل 500ms
            cpuTimer = new System.Windows.Forms.Timer { Interval = 500 };
            cpuTimer.Tick += (s, e) => UpdateCpuDisplay();
            cpuTimer.Start();
        }

        private void UpdateCpuDisplay()
        {
            try
            {
                if (cpuCounter != null)
                {
                    float cpuUsage = cpuCounter.NextValue();
                    lblCpuDisplay.Text = $"CPU: {cpuUsage:F1}%";
                    
                    // تغيير اللون حسب الاستهلاك
                    if (cpuUsage < 30)
                        lblCpuDisplay.ForeColor = Color.Green;
                    else if (cpuUsage < 70)
                        lblCpuDisplay.ForeColor = Color.Orange;
                    else
                        lblCpuDisplay.ForeColor = Color.Red;
                }
            }
            catch { }
        }

