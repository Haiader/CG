// PERFORMANCE MONITORING INTEGRATION EXAMPLES
// This file demonstrates how the monitoring system has been integrated into Form1.cs

// ============================================================================
// EXAMPLE 1: Basic Algorithm Integration (DDA Algorithm)
// ============================================================================

private void button12_Click(object sender, EventArgs e)
{
    // BEGIN MEASUREMENT
    // This captures the algorithm name and detects the current slow/fast mode
    // automatically from the IsSlow() method which checks the toggle state.
    BeginPerformanceMeasurement("DDA");
    
    ClearCanvas();
    RunDDA(50, 50, 100, 300, Color.Red, bmp, pictureBox1);
    
    // END MEASUREMENT
    // This:
    // 1. Computes elapsed time since BeginMeasurement()
    // 2. Obtains current CPU usage from Windows Performance Counter
    // 3. Calculates memory differential (if any)
    // 4. Stores the snapshot in PerformanceMonitor's internal history
    // 5. Updates the lblPerformanceMetrics display label on the right
    EndPerformanceMeasurement();
}

// ============================================================================
// EXAMPLE 2: Multiple Algorithm Calls (Composite Algorithm)
// ============================================================================

private void button15_Click(object sender, EventArgs e)
{
    // When an algorithm makes multiple internal calls (as seen here with 8 RunMidpointCircle calls),
    // we measure the ENTIRE operation as a single unit. This gives us the total time
    // and resource cost of the composite drawing operation.
    
    BeginPerformanceMeasurement("CompositeCircles");
    ClearCanvas();
    
    int xc = pictureBox1.Width / 2;
    int yc = pictureBox1.Height / 2;

    // All of these RunMidpointCircle calls happen between Begin and End measurement
    // They execute in the same mode (both detect IsSlow("CompositeCircles"))
    RunMidpointCircle(xc, yc, 120, Color.Black, bmp);
    RunMidpointCircle(xc - 50, yc - 30, 25, Color.Blue, bmp);
    RunMidpointCircle(xc - 50, yc - 30, 7, Color.Black, bmp);
    RunMidpointCircle(xc + 50, yc - 30, 25, Color.Blue, bmp);
    RunMidpointCircle(xc + 50, yc - 30, 7, Color.Black, bmp);
    RunMidpointCircle(xc - 100, yc - 90, 45, Color.Gray, bmp);
    RunMidpointCircle(xc + 100, yc - 90, 45, Color.Gray, bmp);
    RunMidpointCircle(xc, yc + 60, 30, Color.Red, bmp);

    pictureBox1.Image = bmp;
    
    // The measurement captures the TOTAL time for drawing all 8 circles
    // Result might show: "CompositeCircles: 45.23ms SLOW"
    EndPerformanceMeasurement();
}

// ============================================================================
// EXAMPLE 3: Algorithm with Nested Loops (Filled Square)
// ============================================================================

private void button2_Click(object sender, EventArgs e)
{
    BeginPerformanceMeasurement("FilledSquare");
    ClearCanvas();

    int x = 100;
    int y = 100;
    bool slow = IsSlow("FilledSquare");

    // This nested loop (100x100 = 10,000 SetPixel calls) is a good example
    // of why slow-motion mode shows huge time differences.
    // SLOW: Each iteration might refresh the screen → very slow
    // FAST: Only one final refresh → very fast
    for (int i = 0; i < 100; i++)
    {
        for (int j = 0; j < 100; j++)
        {
            bmp.SetPixel(x + i, y + j, Color.Red);
        }
        if (slow && i % 4 == 0)  // Refresh every 4 iterations for performance
        {
            pictureBox1.Image = bmp;
            pictureBox1.Refresh();
            Thread.Sleep(6);  // Pause for visualization
        }
    }
    pictureBox1.Image = bmp;
    
    // Expected comparison:
    // SLOW: ~150ms (10,000 pixels + 25 refreshes + sleep time)
    // FAST: ~2ms (10,000 pixels + 1 refresh)
    // Ratio: ~75x slower (10,000 pixels dominates, but slow mode adds overhead)
    EndPerformanceMeasurement();
}

