// ============================================================================
// EXAMPLE 5: Accessing Measurements Programmatically
// ============================================================================

// After running algorithms, you can query the metrics:

public void ShowPerformanceAnalysis()
{
    // Get all snapshots for a specific algorithm
    var dda_snapshots = PerformanceMonitor.GetMetrics("DDA");
    
    Console.WriteLine($"DDA was run {dda_snapshots.Count} times:");
    foreach (var snapshot in dda_snapshots)
    {
        Console.WriteLine($"  - {snapshot.ExecutionTimeMs:F2}ms in {(snapshot.IsSlowMode ? "SLOW" : "FAST")} mode");
    }

    // Get just the latest measurement
    var latest = PerformanceMonitor.GetLatestSnapshot("Midpoint Circle");
    if (latest != null)
    {
        Console.WriteLine($"Latest Midpoint Circle run: {latest.ExecutionTimeMs:F2}ms using {latest.MemoryMB:F3}MB");
    }

    // Generate a comparison report
    string comparison = PerformanceMonitor.GetPerformanceComparison("StandardCircle");
    Console.WriteLine(comparison);

    // Generate a complete summary
    string summary = PerformanceMonitor.GetSummaryReport();
    Console.WriteLine(summary);
}

// ============================================================================
// EXAMPLE 6: How the Display Label Updates
// ============================================================================

// After EndPerformanceMeasurement(), this method is automatically called:

private void UpdatePerformanceDisplay(string algorithmName, PerformanceSnapshot snapshot)
{
    // Thread-safe invoke (only shown in conceptual form here)
    if (InvokeRequired)
    {
        Invoke(new Action(() => UpdatePerformanceDisplay(algorithmName, snapshot)));
        return;
    }

    // Build display text with latest metrics and comparison
    string displayText = "PERFORMANCE METRICS\n";
    displayText += "═══════════════════════════════════\n\n";

    displayText += $"Algorithm: {algorithmName}\n";
    displayText += $"Mode: {(snapshot.IsSlowMode ? "SLOW (Animated)" : "FAST (Direct)")}\n\n";

    displayText += "Last Execution:\n";
    displayText += $"  Time:   {snapshot.ExecutionTimeMs:F2} ms\n";
    displayText += $"  CPU:    {snapshot.CpuPercent:F1} %\n";
    displayText += $"  Memory: {snapshot.MemoryMB:F3} MB\n\n";

    // Try to get comparison between slow and fast modes
    string comparison = PerformanceMonitor.GetPerformanceComparison(algorithmName);
    if (!comparison.Contains("Insufficient"))
    {
        displayText += "SLOW vs FAST Comparison:\n";
        displayText += comparison + "\n";
    }

    displayText += "\n[Double-click to copy]";

    lblPerformanceMetrics.Text = displayText;

    // Label now displays something like:
    // ═══════════════════════════════════════
    // PERFORMANCE METRICS
    // ═══════════════════════════════════════
    // 
    // Algorithm: DDA
    // Mode: FAST (Direct)
    // 
    // Last Execution:
    //   Time:   8.76 ms
    //   CPU:    5.3 %
    //   Memory: 0.001 MB
    // 
    // SLOW vs FAST Comparison:
    // DDA
    // ─────────────────────
    // SLOW: 125.43ms | 15.2%
    // FAST: 8.76ms | 5.3%
    // ─────────────────────
    // Ratio: 14.31x slower
    // CPU Δ: +9.9%
    //
    // [Double-click to copy]
}

